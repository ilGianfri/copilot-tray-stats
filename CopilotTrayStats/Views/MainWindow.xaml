<Window x:Class="CopilotTrayStats.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CopilotTrayStats.ViewModels"
        Title="Copilot Stats"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Deactivated="Window_Deactivated">

    <!-- UsageBar references the ViewModel enum so must stay in Window.Resources -->
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Thin modern horizontal scrollbar -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#21262d" CornerRadius="3" Height="6" VerticalAlignment="Center"/>
                            <Track Name="PART_Track" IsDirectionReversed="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                  Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#484f58" CornerRadius="3" Height="6"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                                  Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Row="0" Margin="{TemplateBinding Padding}"/>
                            <ScrollBar Grid.Row="1" Name="PART_HorizontalScrollBar"
                                       Style="{StaticResource ThinScrollBar}"
                                       Orientation="Horizontal"
                                       Margin="0,3,0,0"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       Minimum="0"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UsageBar" TargetType="ProgressBar">
            <Setter Property="Height"          Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="#21262d"/>
            <Setter Property="Foreground"      Value="{StaticResource GoodBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UsageLevel}" Value="{x:Static vm:UsageLevel.Warning}">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding UsageLevel}" Value="{x:Static vm:UsageLevel.Critical}">
                    <Setter Property="Foreground" Value="{StaticResource CriticalBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding UsageLevel}" Value="{x:Static vm:UsageLevel.Unknown}">
                    <Setter Property="Foreground" Value="{StaticResource UnknownBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- ── History panel (left, toggled by chart button) ── -->
        <Border x:Name="HistoryPanel" Grid.Column="0" Width="400" Margin="8,8,4,8"
                Visibility="Collapsed" CornerRadius="8"
                Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.6" ShadowDepth="4"/>
            </Border.Effect>
            <StackPanel>
                <!-- Header -->
                <Border Background="{StaticResource SubtleBg}" CornerRadius="8,8,0,0" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Usage History"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="HistorySubtitle"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="✕" Width="22" Height="22"
                                Background="Transparent" Foreground="{StaticResource TextSecondary}"
                                BorderThickness="0" FontSize="11" Cursor="Hand"
                                Click="CloseHistoryPanel_Click"/>
                    </Grid>
                </Border>
                <!-- Chart area -->
                <StackPanel Margin="12,10,12,12">
                    <Border Background="{StaticResource SubtleBg}" CornerRadius="6"
                            Padding="0" MinHeight="210">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Y-axis labels -->
                            <Grid Grid.Column="0" Height="180" Width="28"
                                  Margin="0,12,4,0" VerticalAlignment="Top">
                                <TextBlock x:Name="YAxisMax"
                                           FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Top"
                                           Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock x:Name="YAxisMid"
                                           FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="0"
                                           FontSize="9" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                           Foreground="{StaticResource TextSecondary}"/>
                            </Grid>

                            <!-- Bars -->
                            <ScrollViewer Grid.Column="1" Margin="0,12,10,8"
                                          Style="{StaticResource ThinScrollViewer}"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="BarsItemsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Width="32" Margin="2,0">
                                                <Grid Height="210">
                                                    <Border VerticalAlignment="Bottom"
                                                            Height="{Binding BarHeight}"
                                                            MinHeight="2"
                                                            CornerRadius="2,2,0,0"
                                                            ToolTip="{Binding Tooltip}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource TextSecondary}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource TextPrimary}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding DateLabel}"
                                                           FontSize="9" HorizontalAlignment="Center"
                                                           Margin="0,4,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="HistoryEmptyText"
                               Text="No usage data yet. Data is recorded each time the stats refresh."
                               Foreground="{StaticResource TextSecondary}"
                               FontSize="10" TextWrapping="Wrap"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,8,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Main content (right) ── -->
        <Border Grid.Column="1" Width="360" Margin="8" CornerRadius="8"
                Background="{StaticResource CardBg}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.6" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
            <StackPanel>

            <!-- ── Title bar ── -->
            <Border Background="{StaticResource SubtleBg}" CornerRadius="8,8,0,0"
                    Padding="14,10" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"
                              SnapsToDevicePixels="True" Cursor="Hand"
                              MouseLeftButtonDown="CopilotIcon_MouseLeftButtonDown">
                            <Path.Data>
                                <PathGeometry FillRule="EvenOdd" Figures="M19.245 5.364c1.322 1.36 1.877 3.216 2.11 5.817.622 0 1.2.135 1.592.654l.73.964c.21.278.323.61.323.955v2.62c0 .339-.173.669-.453.868C20.239 19.602 16.157 21.5 12 21.5c-4.6 0-9.205-2.583-11.547-4.258-.28-.2-.452-.53-.453-.868v-2.62c0-.345.113-.679.321-.956l.73-.963c.392-.517.974-.654 1.593-.654l.029-.297c.25-2.446.81-4.213 2.082-5.52 2.461-2.54 5.71-2.851 7.146-2.864h.198c1.436.013 4.685.323 7.146 2.864zm-7.244 4.328c-.284 0-.613.016-.962.05-.123.447-.305.85-.57 1.108-1.05 1.023-2.316 1.18-2.994 1.18-.638 0-1.306-.13-1.851-.464-.516.165-1.012.403-1.044.996a65.882 65.882 0 00-.063 2.884l-.002.48c-.002.563-.005 1.126-.013 1.69.002.326.204.63.51.765 2.482 1.102 4.83 1.657 6.99 1.657 2.156 0 4.504-.555 6.985-1.657a.854.854 0 00.51-.766c.03-1.682.006-3.372-.076-5.053-.031-.596-.528-.83-1.046-.996-.546.333-1.212.464-1.85.464-.677 0-1.942-.157-2.993-1.18-.266-.258-.447-.661-.57-1.108-.32-.032-.64-.049-.96-.05zm-2.525 4.013c.539 0 .976.426.976.95v1.753c0 .525-.437.95-.976.95a.964.964 0 01-.976-.95v-1.752c0-.525.437-.951.976-.951zm5 0c.539 0 .976.426.976.95v1.753c0 .525-.437.95-.976.95a.964.964 0 01-.976-.95v-1.752c0-.525.437-.951.976-.951zM7.635 5.087c-1.05.102-1.935.438-2.385.906-.975 1.037-.765 3.668-.21 4.224.405.394 1.17.657 1.995.657h.09c.649-.013 1.785-.176 2.73-1.11.435-.41.705-1.433.675-2.47-.03-.834-.27-1.52-.63-1.813-.39-.336-1.275-.482-2.265-.394zm6.465.394c-.36.292-.6.98-.63 1.813-.03 1.037.24 2.06.675 2.47.968.957 2.136 1.104 2.776 1.11h.044c.825 0 1.59-.263 1.995-.657.555-.556.765-3.187-.21-4.224-.45-.468-1.335-.804-2.385-.906-.99-.088-1.875.058-2.265.394zM12 7.615c-.24 0-.525.015-.84.044.03.16.045.336.06.526l-.001.159a2.94 2.94 0 01-.014.25c.225-.022.425-.027.612-.028h.366c.187 0 .387.006.612.028-.015-.146-.015-.277-.015-.409.015-.19.03-.365.06-.526a9.29 9.29 0 00-.84-.044z"/>
                            </Path.Data>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="{StaticResource GoodBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UsageLevel}" Value="{x:Static vm:UsageLevel.Warning}">
                                            <Setter Property="Fill" Value="{StaticResource WarningBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding UsageLevel}" Value="{x:Static vm:UsageLevel.Critical}">
                                            <Setter Property="Fill" Value="{StaticResource CriticalBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding UsageLevel}" Value="{x:Static vm:UsageLevel.Unknown}">
                                            <Setter Property="Fill" Value="{StaticResource UnknownBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                        <TextBlock Text="GitHub Copilot"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button FontFamily="Segoe Fluent Icons" Content="&#xE9D2;" Width="22" Height="22"
                                Background="Transparent" Foreground="{StaticResource TextSecondary}"
                                BorderThickness="0" FontSize="11" Cursor="Hand"
                                ToolTip="Usage history"
                                Click="ChartButton_Click"/>
                        <Button FontFamily="Segoe Fluent Icons" Content="&#xE713;" Width="22" Height="22"
                                Background="Transparent" Foreground="{StaticResource TextSecondary}"
                                BorderThickness="0" FontSize="11" Cursor="Hand"
                                Click="SettingsButton_Click"/>
                        <Button FontFamily="Segoe Fluent Icons" Content="&#xE711;" Width="22" Height="22"
                                Background="Transparent" Foreground="{StaticResource TextSecondary}"
                                BorderThickness="0" FontSize="11" Cursor="Hand"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── Body ── -->
            <StackPanel Margin="14,12,14,14" >

                <!-- Error banner -->
                <Border Background="#3d1313" BorderBrush="{StaticResource CriticalBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,0,0,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource CriticalBrush}"
                               FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <!-- Username + Plan row -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Signed in as"/>
                        <TextBlock Style="{StaticResource ValueStyle}" Text="{Binding Username}"
                                   FontSize="14"/>
                    </StackPanel>
                    <Border Grid.Column="1" VerticalAlignment="Center" CornerRadius="12"
                            Background="#21262d" BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1" Padding="8,3">
                        <TextBlock Text="{Binding PlanType}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="11"/>
                    </Border>
                </Grid>

                <!-- Premium requests section — hidden when unlimited -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUnlimited}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Premium requests header -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource LabelStyle}" Text="{Binding DisplayLabel, Mode=OneWay}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimary}">
                            <Run Text="{Binding DisplayCount, Mode=OneWay}"/>
                            <Run Text=" / " Foreground="{StaticResource TextSecondary}"/>
                            <Run Text="{Binding PremiumTotal, Mode=OneWay}" Foreground="{StaticResource TextSecondary}"/>
                            <Run Text=" " Foreground="{StaticResource TextSecondary}"/>
                            <Run Text="{Binding DisplayPercentLabel, Mode=OneWay}" Foreground="{StaticResource TextSecondary}"/>
                        </TextBlock>
                    </Grid>

                    <!-- Progress bar -->
                    <ProgressBar Style="{StaticResource UsageBar}"
                                 Minimum="0" Maximum="{Binding PremiumTotal}"
                                 Value="{Binding PremiumUsed}"
                                 Margin="0,0,0,8"/>

                    <!-- Overage warning -->
                    <Border Background="#2d1b00" BorderBrush="{StaticResource WarningBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="8,5" Margin="0,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasOverage}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Foreground="{StaticResource WarningBrush}" FontSize="11">
                            <Run Text="⚠ "/>
                            <Run Text="{Binding OverageCount, Mode=OneWay}"/>
                            <Run Text=" overage request(s) used"/>
                        </TextBlock>
                    </Border>

                    <!-- Reset date -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Resets" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource ValueStyle}"
                                   FontSize="12" Text="{Binding ResetAt}"/>
                    </Grid>
                </StackPanel>

                <!-- Unlimited badge -->
                <Border CornerRadius="6" Background="#1a3a2a" BorderBrush="{StaticResource GoodBrush}"
                        BorderThickness="1" Padding="10,6" Margin="0,0,0,12">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUnlimited}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="✓ Unlimited premium requests on this plan"
                               Foreground="{StaticResource GoodBrush}" FontSize="12"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Separator -->
                <Rectangle Height="1" Fill="{StaticResource BorderColor}" Margin="0,0,0,10"/>

                <!-- ── Other quotas ── -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource LabelStyle}"
                               Text="Other quotas" Margin="0,0,0,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Text="Chat" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Text="{Binding ChatStatus}" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Text="Completions"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}" Text="{Binding CompletionsStatus}"/>
                </Grid>

                <!-- ── Feature chips ── -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Border CornerRadius="10" Padding="7,2" Margin="0,0,6,0" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#21262d"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMcpEnabled}" Value="True">
                                        <Setter Property="Background" Value="#1a2e1a"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource GoodBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMcpEnabled}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource GoodBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="MCP"/>
                        </TextBlock>
                    </Border>
                    <Border CornerRadius="10" Padding="7,2" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#21262d"/>
                                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsChatEnabled}" Value="True">
                                        <Setter Property="Background" Value="#1a2e1a"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource GoodBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChatEnabled}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource GoodBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Chat"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Height="1" Fill="{StaticResource BorderColor}" Margin="0,0,0,12"/>

                <!-- Last refreshed + Refresh button -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Last refreshed"/>
                        <TextBlock Style="{StaticResource ValueStyle}" FontSize="11" FontWeight="Normal"
                                   Text="{Binding LastRefreshed}" Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                            Content="Refresh" Command="{Binding RefreshCommand}"/>
                </Grid>

                <!-- ── Debug expander ── -->
                <Expander Margin="0,10,0,0" IsExpanded="False"
                          Visibility="{Binding IsDebugVisible, Converter={StaticResource BoolToVis}}">
                    <Expander.Header>
                        <TextBlock Text="Raw API response" Style="{StaticResource LabelStyle}" Margin="0"/>
                    </Expander.Header>
                    <StackPanel Margin="0,6,0,0">
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding RawJson, Mode=OneWay}"
                                     Background="#0d1117" Foreground="#7ee787"
                                     FontFamily="Consolas" FontSize="10"
                                     BorderThickness="1" BorderBrush="{StaticResource BorderColor}"
                                     Padding="6" IsReadOnly="True"
                                     TextWrapping="NoWrap"/>
                        </ScrollViewer>
                        <Button Content="Copy to clipboard" Margin="0,6,0,0"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Right"
                                Command="{Binding CopyJsonCommand}"/>
                    </StackPanel>
                </Expander>

            </StackPanel>
        </StackPanel>
            <ProgressBar IsIndeterminate="True" Height="2" VerticalAlignment="Bottom"
                         Background="{StaticResource BorderColor}" BorderThickness="0"
                         Foreground="{StaticResource GoodBrush}" Margin="3,0,0,0"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </Grid>
    </Border>
</Grid>
</Window>
